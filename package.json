{
  "name": "trueid-office",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"tsx server/index.ts\"",
    "dev:funnel": "VITE_DEV_HTTPS=0 concurrently -k -n web,api -c cyan,magenta \"vite\" \"tsx server/index.ts\"",
    "dev:web": "vite",
    "dev:server": "tsx server/index.ts",
    "funnel:on": "bash scripts/enable-funnel.sh",
    "funnel:install-agent": "bash scripts/install-funnel-agent.sh",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "start": "tsx server/index.ts",
    "start:all": "npm run build && concurrently -k -n web,api \"npm run preview\" \"npm run start\"",
    "share-info": "node scripts/share-info.mjs",
    "restart:host": "bash scripts/jenkins-restart.sh"
  },
  "dependencies": {
    "nanoid": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "ws": "^8.21.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "pm2": "^6.0.14",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
